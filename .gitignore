# Root .gitignore for consolidated Option CSP project

# Next.js (vercel-app)
vercel-app/node_modules/
vercel-app/.next/
vercel-app/.vercel/
vercel-app/*.log
vercel-app/.env*

# Python (streamlit_app)
streamlit_app/__pycache__/
streamlit_app/*.py[cod]
streamlit_app/*$py.class
streamlit_app/.venv/
streamlit_app/venv/
streamlit_app/ENV/

# System
.DS_Store
Thumbs.db
